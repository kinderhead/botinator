{
    "entryPoints": [
        "src"
    ],
    "out": "docs",
    "plugin": [
        "typedoc-plugin-djs-links",
        "typedoc-theme-hierarchy"
    ],
    "theme": "hierarchy",
    "exclude": [
        "**/node_modules/**"
    ],
    "externalSymbolLinkMappings": {
        "@discordjs/builders": {
            "SlashCommandBuilder": "#"
        }
    }
}